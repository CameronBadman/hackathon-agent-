project_id              = "your-gcp-project-id"
region                  = "australia-southeast1"
timezone                = "Australia/Brisbane"
agent_schedule          = "0 9 * * 1"
renew_schedule          = "0 6 */6 * *"

# Secret values (do not commit real values)
gemini_api_key          = "your-gemini-api-key"
gemini_model            = "gemini-2.5-flash"
discovery_window_days   = 35
max_discovery_results   = 80
quality_score_threshold = 0.65
target_account_email    = "you@example.com"
google_oauth_client_id     = "your-oauth-client-id.apps.googleusercontent.com"
google_oauth_client_secret = "your-oauth-client-secret"
google_oauth_refresh_token = "your-oauth-refresh-token"

bot_calendar_id         = "primary"
calendar_webhook_token  = "generate-a-long-random-token"

firestore_collection    = "hackathons"
system_collection       = "_system"
